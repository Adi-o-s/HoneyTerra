# Copy to .env.local and fill in. Never commit .env.local.

# ── Supabase (Database + Auth + Storage) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string for Drizzle (use the Supabase "Connection pooling" URL).
DATABASE_URL=

# ── Razorpay (Payments) ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Resend (Transactional email) ─────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="HoneyTerra <orders@honeyterra.com>"

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Secret for signing public order-page access tokens. Any long random string.
# Falls back to RAZORPAY_KEY_SECRET if unset, but set a dedicated one for prod.
ORDER_TOKEN_SECRET=
